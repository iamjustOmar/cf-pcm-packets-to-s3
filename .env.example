KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=packets-topic
KAFKA_KEY=
KAFKA_GROUP_ID=packet-local-chunker
# SASL/PLAIN auth (leave empty to disable)
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
CHUNK_SIZE_MB=5
OUTPUT_DIR=./output
PCM_SAMPLE_RATE=48000
PCM_CHANNELS=1

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# AWS S3
S3_BUCKET=my-audio-bucket
S3_REGION=us-east-1
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
